{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#f8fbff",
  "padding": 20,
  "title": {
    "text": "How is cardiovascular mortality projected to change by 2050?",
    "subtitle": "Selected countries shown from 2025 to 2050 using age-standardised mortality rates",
    "anchor": "start",
    "fontSize": 23,
    "subtitleFontSize": 13,
    "fontWeight": "bold",
    "color": "#071d3a",
    "subtitleColor": "#475569"
  },
  "width": 820,
  "height": 430,
  "data": {
    "url": "../data/global_cvd_burden_2025_2050.csv"
  },
  "transform": [
    {
      "filter": "indexof(['Australia', 'India', 'China', 'United States', 'Germany', 'Japan'], datum.country) >= 0"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year"
        },
        "y": {
          "field": "age_std_mortality_rate_per_100k",
          "type": "quantitative",
          "title": "Mortality rate per 100,000 people",
          "scale": {"zero": false}
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "title": "Country",
          "scale": {
            "domain": ["Australia", "India", "China", "United States", "Germany", "Japan"],
            "range": ["#facc15", "#2563eb", "#0ea5e9", "#7c3aed", "#64748b", "#ef4444"]
          }
        },
        "strokeWidth": {
          "condition": {
            "test": "datum.country == 'Australia'",
            "value": 5
          },
          "value": 2
        },
        "opacity": {
          "condition": {
            "test": "datum.country == 'Australia'",
            "value": 1
          },
          "value": 0.75
        },
        "tooltip": [
          {"field": "country", "title": "Country"},
          {"field": "year", "title": "Year"},
          {
            "field": "age_std_mortality_rate_per_100k",
            "title": "Mortality rate",
            "format": ".1f"
          },
          {
            "field": "healthcare_pressure_score",
            "title": "Healthcare pressure",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.country == 'Australia' && datum.year == 2050"}
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "dy": -8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#071d3a",
        "text": "Australia remains comparatively low"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "age_std_mortality_rate_per_100k",
          "type": "quantitative"
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#dbe4ee"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}