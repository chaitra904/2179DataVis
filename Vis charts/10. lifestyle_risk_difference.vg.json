{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#fffdfb",
  "padding": 20,
  "title": {
    "text": "Which lifestyle and clinical factors separate high-risk patients?",
    "subtitle": "Bars show percentage difference in average values between high-risk and low-risk patients.",
    "anchor": "start",
    "fontSize": 24,
    "subtitleFontSize": 13,
    "fontWeight": "bold",
    "color": "#5a2436",
    "subtitleColor": "#7b646b"
  },
  "width": 720,
  "height": 340,
  "data": {
    "values": [
      {"factor": "Cholesterol", "pct_difference": 1.3, "direction": "Higher in high-risk patients"},
      {"factor": "Exercise hours", "pct_difference": 1.4, "direction": "Higher in high-risk patients"},
      {"factor": "Triglycerides", "pct_difference": 1.2, "direction": "Higher in high-risk patients"},
      {"factor": "Sedentary time", "pct_difference": -0.7, "direction": "Lower in high-risk patients"},
      {"factor": "Sleep duration", "pct_difference": -1.1, "direction": "Lower in high-risk patients"},
      {"factor": "Stress", "pct_difference": -0.4, "direction": "Lower in high-risk patients"}
    ]
  },
  "transform": [
    {
      "calculate": "abs(datum.pct_difference)",
      "as": "abs_difference"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 6
      },
      "encoding": {
        "y": {
          "field": "factor",
          "type": "nominal",
          "sort": {
            "field": "abs_difference",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "labelFontSize": 13,
            "labelFontWeight": "bold",
            "labelColor": "#2d1b22"
          }
        },
        "x": {
          "field": "pct_difference",
          "type": "quantitative",
          "title": "% difference from low-risk patients",
          "scale": {
            "domain": [-1.5, 1.6]
          },
          "axis": {
            "grid": true,
            "gridColor": "#f0ddd6",
            "labelColor": "#6f5b61",
            "format": ".1f",
            "tickCount": 7
          }
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "Higher in high-risk patients",
              "Lower in high-risk patients"
            ],
            "range": ["#d1495b", "#5c7c77"]
          }
        },
        "tooltip": [
          {"field": "factor", "title": "Factor"},
          {"field": "pct_difference", "title": "% difference", "format": "+.1f"},
          {"field": "direction", "title": "Interpretation"}
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#5a2436",
        "strokeWidth": 1.4
      },
      "encoding": {
        "x": {"datum": 0}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 7,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#2d1b22"
      },
      "encoding": {
        "y": {
          "field": "factor",
          "type": "nominal",
          "sort": {
            "field": "abs_difference",
            "order": "descending"
          }
        },
        "x": {
          "field": "pct_difference",
          "type": "quantitative"
        },
        "text": {
          "field": "pct_difference",
          "type": "quantitative",
          "format": "+.1f"
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {
      "domain": false,
      "ticks": false,
      "titleColor": "#5a2436",
      "titleFontWeight": "bold"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#2d1b22"
    }
  }
}